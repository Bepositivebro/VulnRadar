{
  "name": "vulnradar",
  "displayName": "VulnRadar",
  "description": "Real-time vulnerability scanner for VS Code",
  "version": "1.0.1",
  "publisher": "Codingwell07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bepositivebro/VulnRadar.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:pip-requirements"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vulnradar.scanFile",
        "title": "VulnRadar: Scan Current File"
      },
      {
        "command": "vulnradar.openDashboard",
        "title": "VulnRadar: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "VulnRadar",
      "properties": {
        "vulnradar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time vulnerability scanning"
        },
        "vulnradar.debounceMs": {
          "type": "number",
          "default": 1000,
          "description": "Delay (ms) after typing before scanning"
        }
      }
    }
  },
  "scripts": {
    "install-deps": "npm install"
  },
  "dependencies": {
    "node-fetch": "^2.6.9"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}